{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build:debug",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "EcsEngine.slnx",
                "-c",
                "Debug",
                "-v",
                "minimal"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build:release",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "EcsEngine.slnx",
                "-c",
                "Release",
                "-v",
                "minimal"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {

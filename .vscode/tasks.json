            "command": "dotnet",
            "type": "shell",
            "args": [
                "test",
                "EcsEngine.slnx",
                "-v",
                "minimal",
                "--no-build"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": "$msCompile",
            "dependsOn": "build:debug"
        },

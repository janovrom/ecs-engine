root = true

# All files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]
# Naming rules
# Private/protected/internal readonly fields: _PascalCase (underscore prefix + PascalCase)
dotnet_naming_style.readonly_pascal_case.capitalization = pascal_case
dotnet_naming_style.readonly_pascal_case.required_prefix = _
dotnet_naming_rule.readonly_fields_pascal_case.symbols = readonly_fields
dotnet_naming_rule.readonly_fields_pascal_case.style = readonly_pascal_case
dotnet_naming_rule.readonly_fields_pascal_case.severity = suggestion
dotnet_naming_symbols.readonly_fields.applicable_kinds = field
dotnet_naming_symbols.readonly_fields.applicable_accessibilities = private, protected, internal, protected_internal, private_protected
dotnet_naming_symbols.readonly_fields.required_modifiers = readonly

# Public readonly fields and properties: PascalCase (no prefix)
dotnet_naming_style.pure_pascal_case.capitalization = pascal_case
dotnet_naming_rule.public_readonly_pascal_case.symbols = public_readonly
dotnet_naming_rule.public_readonly_pascal_case.style = pure_pascal_case
dotnet_naming_rule.public_readonly_pascal_case.severity = suggestion
dotnet_naming_symbols.public_readonly.applicable_kinds = field, property
dotnet_naming_symbols.public_readonly.applicable_accessibilities = public
dotnet_naming_symbols.public_readonly.required_modifiers = readonly

# Abstract class naming
dotnet_naming_style.abstract_class_base_suffix.capitalization = pascal_case
dotnet_naming_style.abstract_class_base_suffix.required_suffix = Base
dotnet_naming_rule.abstract_class_names.symbols = abstract_classes
dotnet_naming_rule.abstract_class_names.style = abstract_class_base_suffix
dotnet_naming_rule.abstract_class_names.severity = suggestion
dotnet_naming_symbols.abstract_classes.applicable_kinds = class
dotnet_naming_symbols.abstract_classes.required_modifiers = abstract

# Constants: PascalCase
dotnet_naming_style.constant_pascal_case.capitalization = pascal_case
dotnet_naming_rule.constants_pascal_case.symbols = constants
dotnet_naming_rule.constants_pascal_case.style = constant_pascal_case
dotnet_naming_rule.constants_pascal_case.severity = suggestion
dotnet_naming_symbols.constants.applicable_kinds = field, local
dotnet_naming_symbols.constants.required_modifiers = const

# Language features
csharp_prefer_simple_using_statement = true:suggestion
csharp_prefer_braces = true:silent
csharp_style_namespace_declarations = file_scoped:suggestion

# Var usage
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = false:suggestion

# New expression
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# Collections
csharp_style_expression_bodied_methods = false:silent
csharp_style_deconstructed_variable_declaration = true:suggestion

# Code organization
csharp_prefer_static_local_function = true:suggestion
csharp_prefer_pattern_matching = true:silent

# Indentation and wrapping
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = no_change
csharp_wrap_array_initializer_style = chop_if_multiline
